# Hi Tom Fleet — environment variables
# Copy to .env.local and fill in your values

# ── MOCK MODE (no Supabase needed) ────────────────────────────
# Set to "true" to run with local mock data (for development/demo)
VITE_MOCK_MODE=true

# ── SUPABASE ───────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── PUSH NOTIFICATIONS (optional) ─────────────────────────────
# VAPID key from your Firebase project → Project Settings → Cloud Messaging
VITE_FCM_VAPID_KEY=your-vapid-key-here
